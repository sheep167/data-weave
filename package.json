{
    "name": "data-weave",
    "private": true,
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml,css}": [
            "prettier --write"
        ]
    },
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "turbo": "^2.9.8",
        "typescript-eslint": "^8.59.2"
    }
}
